{
  "name": "@harryaskham/pi-daemon",
  "version": "0.1.0",
  "description": "General-purpose daemon that multiplexes on-demand Pi SDK agent sessions in one Node process",
  "type": "module",
  "license": "MIT",
  "private": false,
  "workspaces": [
    "web"
  ],
  "engines": {
    "node": ">=22.19.0"
  },
  "bin": {
    "pi-daemon": "dist/cli.js",
    "pi-daemon-rpc": "dist/rpc-stdio-cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./protocol": {
      "types": "./dist/protocol.d.ts",
      "import": "./dist/protocol.js"
    },
    "./protocol.schema.json": "./dist/protocol.schema.json",
    "./session-api": {
      "types": "./dist/session-api.d.ts",
      "import": "./dist/session-api.js"
    },
    "./session-config": {
      "types": "./dist/session-config.d.ts",
      "import": "./dist/session-config.js"
    },
    "./rpc-bridge": {
      "types": "./dist/rpc-bridge.d.ts",
      "import": "./dist/rpc-bridge.js"
    },
    "./dashboard-contract": {
      "types": "./dist/dashboard-contract.d.ts",
      "import": "./dist/dashboard-contract.js"
    },
    "./schedule-contract": {
      "types": "./dist/schedule-contract.d.ts",
      "import": "./dist/schedule-contract.js"
    },
    "./schedule-store": {
      "types": "./dist/schedule-store.d.ts",
      "import": "./dist/schedule-store.js"
    },
    "./dashboard-backend": {
      "types": "./dist/dashboard-backend.d.ts",
      "import": "./dist/dashboard-backend.js"
    },
    "./dashboard-remote-backend": {
      "types": "./dist/dashboard-remote-backend.d.ts",
      "import": "./dist/dashboard-remote-backend.js"
    },
    "./dashboard-auth": {
      "types": "./dist/dashboard-auth.d.ts",
      "import": "./dist/dashboard-auth.js"
    },
    "./dashboard-store": {
      "types": "./dist/dashboard-store.d.ts",
      "import": "./dist/dashboard-store.js"
    },
    "./dashboard-server": {
      "types": "./dist/dashboard-server.d.ts",
      "import": "./dist/dashboard-server.js"
    },
    "./dashboard-stream-router": {
      "types": "./dist/dashboard-stream-router.d.ts",
      "import": "./dist/dashboard-stream-router.js"
    },
    "./dashboard-service-runtime": {
      "types": "./dist/dashboard-service-runtime.d.ts",
      "import": "./dist/dashboard-service-runtime.js"
    },
    "./dashboard-neutral-api": {
      "types": "./dist/dashboard-neutral-api.d.ts",
      "import": "./dist/dashboard-neutral-api.js"
    },
    "./dashboard-tui-attachments": {
      "types": "./dist/dashboard-tui-attachments.d.ts",
      "import": "./dist/dashboard-tui-attachments.js"
    },
    "./shadow-tui-host": {
      "types": "./dist/shadow-tui-host.d.ts",
      "import": "./dist/shadow-tui-host.js"
    },
    "./shadow-tui-attachments": {
      "types": "./dist/shadow-tui-attachments.d.ts",
      "import": "./dist/shadow-tui-attachments.js"
    },
    "./dashboard-fixtures": {
      "types": "./dist/dashboard-fixtures.d.ts",
      "import": "./dist/dashboard-fixtures.js"
    },
    "./transcript-projector": {
      "types": "./dist/transcript-projector.d.ts",
      "import": "./dist/transcript-projector.js"
    },
    "./session-inventory": {
      "types": "./dist/session-inventory.d.ts",
      "import": "./dist/session-inventory.js"
    },
    "./source-fingerprint": {
      "types": "./dist/source-fingerprint.d.ts",
      "import": "./dist/source-fingerprint.js"
    },
    "./virtual-terminal": {
      "types": "./dist/virtual-terminal.d.ts",
      "import": "./dist/virtual-terminal.js"
    },
    "./session-ownership": {
      "types": "./dist/session-ownership.d.ts",
      "import": "./dist/session-ownership.js"
    },
    "./session-ownership-store": {
      "types": "./dist/session-ownership-store.d.ts",
      "import": "./dist/session-ownership-store.js"
    },
    "./session-api.schema.json": "./dist/session-api.schema.json",
    "./session-api.openapi.json": "./dist/session-api.openapi.json",
    "./dashboard-api.schema.json": "./dist/dashboard-api.schema.json",
    "./dashboard-api.openapi.json": "./dist/dashboard-api.openapi.json",
    "./schedule.schema.json": "./dist/schedule.schema.json"
  },
  "files": [
    "dist",
    "scripts/check-release.mjs",
    "scripts/live-sdk-smoke.mjs",
    "CHANGELOG.md",
    "README.md",
    "SECURITY.md",
    "THIRD_PARTY_NOTICES.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "build": "npm run clean && tsc -p tsconfig.json && npm run web:build && node scripts/postbuild.mjs",
    "prepack": "npm run build",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test --test-concurrency=1 test/*.test.mjs",
    "test:unit": "node --test --test-concurrency=1 test/*.test.mjs",
    "test:pi-sdk": "npm run build && node --test test/pi-sdk-compatibility.test.mjs",
    "test:live": "npm run build && node scripts/live-sdk-smoke.mjs",
    "fixtures:dashboard": "npm run build && node scripts/generate-dashboard-fixtures.mjs",
    "pack:check": "npm pack --dry-run",
    "release:check": "node scripts/check-release.mjs",
    "web:dev": "npm run dev --workspace @harryaskham/pi-daemon-dash",
    "web:build": "npm run build --workspace @harryaskham/pi-daemon-dash",
    "web:test": "npm run test --workspace @harryaskham/pi-daemon-dash",
    "web:e2e": "npm run e2e --workspace @harryaskham/pi-daemon-dash",
    "web:bundle-report": "npm run bundle:report --workspace @harryaskham/pi-daemon-dash"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "1.2.0",
    "@earendil-works/pi-coding-agent": "0.80.6",
    "@earendil-works/pi-tui": "0.80.6",
    "ws": "8.21.0",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "@types/ws": "8.18.1",
    "ajv": "8.20.0",
    "typescript": "5.9.3"
  },
  "keywords": [
    "pi",
    "agent",
    "multiplexer",
    "daemon",
    "sdk"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/harryaskham/pi-daemon.git"
  },
  "bugs": {
    "url": "https://github.com/harryaskham/pi-daemon/issues"
  },
  "homepage": "https://a.skh.am/pi-daemon/"
}
