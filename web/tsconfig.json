{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@harryaskham/pi-daemon/dashboard-contract": ["../src/dashboard-contract.ts"],
      "@harryaskham/pi-daemon/dashboard-fixtures": ["../src/dashboard-fixtures.ts"],
      "@harryaskham/pi-daemon/extension-view-contract": ["../src/extension-view-contract.ts"],
      "@harryaskham/pi-daemon/extension-view-fixtures": ["../src/extension-view-fixtures.ts"],
      "@harryaskham/pi-daemon/dashboard-session-draft-contract": ["../src/dashboard-session-draft-contract.ts"],
      "@harryaskham/pi-daemon/session-api": ["../src/session-api.ts"],
      "@harryaskham/pi-daemon/schedule-contract": ["../src/schedule-contract.ts"],
      "@harryaskham/pi-daemon/dashboard-session-draft-contract": ["../src/dashboard-session-draft-contract.ts"]
    },
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["vite/client"]
  },
  "include": ["src", "vite.config.ts", "playwright.config.ts"]
}
